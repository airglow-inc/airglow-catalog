{
  "id": "focus-hider",
  "name": "Focus Hider",
  "version": "0.3.2",
  "description": "Hides distracting content, enforces time-based access, and messaging focus mode",
  "defaultEnabled": false,
  "userscripts": [
    {
      "file": "userscripts/youtube.ts",
      "matches": [
        "*://www.youtube.com/*"
      ],
      "runAt": "document_start"
    },
    {
      "file": "userscripts/instagram.ts",
      "matches": [
        "*://www.instagram.com/*"
      ],
      "runAt": "document_start"
    },
    {
      "file": "userscripts/x.ts",
      "matches": [
        "*://x.com/*"
      ],
      "runAt": "document_start"
    },
    {
      "file": "userscripts/linkedin.ts",
      "matches": [
        "*://www.linkedin.com/*"
      ],
      "runAt": "document_start",
      "allFrames": true
    },
    {
      "file": "userscripts/gmail.ts",
      "matches": [
        "*://mail.google.com/*"
      ],
      "runAt": "document_end"
    },
    {
      "file": "userscripts/messaging.ts",
      "matches": [
        "*://web.whatsapp.com/*",
        "*://web.telegram.org/*"
      ]
    }
  ]
}
