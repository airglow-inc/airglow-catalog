{
  "id": "howto-helper",
  "name": "How-To Helper",
  "version": "0.1.0",
  "description": "Floating How-To chat that explains how to do things on the current page",
  "defaultEnabled": false,
  "userscripts": [
    {
      "file": "userscripts/main.ts",
      "matches": [
        "<all_urls>"
      ],
      "runAt": "document_idle"
    }
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
