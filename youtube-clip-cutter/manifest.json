{
  "id": "youtube-clip-cutter",
  "visibility": "hidden",
  "name": "YouTube Clip Cutter",
  "version": "0.1.0",
  "description": "Cut clips from YouTube videos",
  "userscripts": [
    {
      "file": "userscripts/youtube.ts",
      "matches": [
        "*://www.youtube.com/watch*"
      ],
      "runAt": "document_idle"
    }
  ],
  "entrypoint": {
    "selector": "#airglow-cut-btn"
  }
}
