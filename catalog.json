            ],
            "runAt": "document_start"
          },
          {
            "file": "userscripts/x.ts",
            "matches": [
              "*://x.com/*"
            ],
            "runAt": "document_start"
          },
          {
            "file": "userscripts/linkedin.ts",
            "matches": [
              "*://www.linkedin.com/*"
            ],
            "runAt": "document_start",
            "allFrames": true
          },
          {
            "file": "userscripts/messaging.ts",
            "matches": [
