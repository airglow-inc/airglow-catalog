              "*://web.telegram.org/*"
            ]
          },
          {
            "file": "userscripts/blocked-sites.ts",
            "matches": [
              "*://*/*"
            ],
            "runAt": "document_start"
          }
        ],
        "_hash": "ad8067b356f8",
        "_hasUi": true,
        "_serverFunctions": []
      }
    },
