{
  "id": "focus-mode",
  "name": "Focus Mode",
  "version": "0.4.2",
  "description": "Hides distracting feeds on YouTube, Instagram, X, LinkedIn, and WhatsApp/Telegram, and fully blocks any sites you add to your block list",
  "defaultEnabled": false,
  "userscripts": [
    {
      "file": "userscripts/youtube.ts",
      "matches": [
        "*://www.youtube.com/*"
      ],
      "runAt": "document_start"
    },
    {
      "file": "userscripts/instagram.ts",
      "matches": [
        "*://www.instagram.com/*"
      ],
      "runAt": "document_start"
    },
    {
      "file": "userscripts/x.ts",
      "matches": [
        "*://x.com/*"
      ],
      "runAt": "document_start"
    },
    {
      "file": "userscripts/linkedin.ts",
      "matches": [
        "*://www.linkedin.com/*"
      ],
      "runAt": "document_start",
      "allFrames": true
    },
    {
      "file": "userscripts/messaging.ts",
      "matches": [
        "*://web.whatsapp.com/*",
        "*://web.telegram.org/*"
      ]
    },
    {
      "file": "userscripts/blocked-sites.ts",
      "matches": [
        "*://*/*"
      ],
      "runAt": "document_start"
    }
  ]
}
